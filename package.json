{
  "name": "electrobun-react-tailwind-vite",
  "version": "1.0.0",
  "description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "typecheck": "tsc --noEmit",
    "build:canary": "vite build && electrobun build --env=canary"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "1.7.7",
    "@blocknote/core": "0.47.0",
    "@blocknote/mantine": "0.47.0",
    "@blocknote/react": "0.47.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@floating-ui/react": "0.27.18",
    "baseui": "16.1.1",
    "electrobun": "1.14.4",
    "emoji-mart": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "styletron-engine-atomic": "1.6.2",
    "styletron-react": "6.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
