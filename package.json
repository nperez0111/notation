{
  "name": "electrobun-react-tailwind-vite",
  "version": "1.0.0",
  "description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
  "type": "module",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "mkdir -p dist && bun run --parallel dev:hmr dev:electrobun",
    "dev:electrobun": "electrobun dev --watch",
    "dev:hmr": "vite --port 5173",
    "typecheck": "oxlint --type-aware && tsgo --noEmit && oxfmt --check .",
    "fmt": "oxfmt .",
    "lint": "oxlint --type-aware",
    "build:canary": "vite build && electrobun build --env=canary",
    "generate:lexicons": "lex-cli generate"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "1.7.7",
    "@blocknote/code-block": "0.47.0",
    "@blocknote/core": "0.47.0",
    "@blocknote/mantine": "0.47.0",
    "@blocknote/react": "0.47.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@floating-ui/react": "0.27.18",
    "baseui": "16.1.1",
    "electrobun": "1.16.0",
    "emoji-mart": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "shiki": "4.0.2",
    "styletron-engine-atomic": "1.6.2",
    "styletron-react": "6.1.1"
  },
  "devDependencies": {
    "@atcute/lex-cli": "2.5.3",
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript/native-preview": "7.0.0-dev.20260326.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.17.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.3"
  }
}
