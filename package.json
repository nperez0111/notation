{
  "name": "electrobun-react-tailwind-vite",
  "version": "1.0.0",
  "description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
  "type": "module",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "mkdir -p dist && bun run --parallel dev:hmr dev:electrobun",
    "dev:electrobun": "electrobun dev --watch",
    "dev:hmr": "vite --port 5173",
    "typecheck": "oxlint --fix --type-aware --type-check && oxfmt .",
    "fmt": "oxfmt .",
    "lint": "oxlint --type-aware",
    "build:canary": "vite build && electrobun build --env=canary",
    "generate:lexicons": "lex-cli generate",
    "demo:auth": "bun run --watch src/auth/demo/server.ts"
  },
  "dependencies": {
    "@atcute/atproto": "3.1.10",
    "@atcute/bluesky": "3.3.0",
    "@atcute/client": "4.2.1",
    "@atcute/oauth-node-client": "1.1.0",
    "@atcute/password-session": "0.1.0",
    "@atcute/standard-site": "1.0.1",
    "@atlaskit/pragmatic-drag-and-drop": "1.7.7",
    "@base-ui/react": "1.4.0",
    "@blocknote/code-block": "0.47.0",
    "@blocknote/core": "0.47.0",
    "@blocknote/mantine": "0.47.0",
    "@blocknote/react": "0.47.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@floating-ui/react": "0.27.18",
    "@fontsource-variable/geist": "5.2.8",
    "@tailwindcss/vite": "4.2.2",
    "better-auth": "1.5.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "electrobun": "1.16.0",
    "emoji-mart": "^5.6.0",
    "hono": "4.12.9",
    "lucide-react": "1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "shadcn": "4.2.0",
    "shiki": "4.0.2",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "untun": "0.1.3"
  },
  "devDependencies": {
    "@atcute/lex-cli": "2.5.3",
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript/native-preview": "7.0.0-dev.20260326.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.17.4",
    "tailwindcss": "4.2.2",
    "vite": "^6.0.3"
  }
}
